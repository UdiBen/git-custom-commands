#!/bin/sh

# This script adds all untracked files, commits, pushes, and creates a PR

message=$1 # First parameter will be the commit message

if [ -z "$1" ]; then
  echo "Commit message is not provided"
  exit 1
fi

pr_title="$message"

git add .
git commit -am "$message"
git push
gh pr create -w --title "$pr_title" --body ""