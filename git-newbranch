#!/bin/sh

# Create a new branch from the latest base branch

usage() {
  cat >&2 <<EOF
Usage:
  git newbranch <branch-name>        # use name directly
  git newbranch <issue-number>       # 3-5 digit number, fetches title from GitHub
  git newbranch <issue-url>          # GitHub issue URL, fetches title from GitHub
EOF
  exit 1
}

# Convert a GitHub issue title to a branch name:
# lowercase, replace spaces with dashes, keep only alphanumeric and dashes, collapse multiple dashes
title_to_branch() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/ /-/g' | sed 's/[^a-z0-9-]//g' | sed 's/-\{2,\}/-/g' | sed 's/^-//;s/-$//'
}

INPUT="$*"
BRANCH_NAME=""

if [ -z "$INPUT" ] || [ "$INPUT" = "-h" ] || [ "$INPUT" = "--help" ]; then
  usage
elif echo "$INPUT" | grep -qE '^https://github\.com/.+/issues/[0-9]+'; then
  # GitHub issue URL
  REPO=$(echo "$INPUT" | sed -n 's|https://github.com/\([^/]*/[^/]*\)/issues/.*|\1|p')
  ISSUE_NUMBER=$(echo "$INPUT" | sed -n 's|.*/issues/\([0-9]*\).*|\1|p')
  [ -z "$REPO" ] || [ -z "$ISSUE_NUMBER" ] && { echo "Invalid GitHub issue URL: $INPUT" >&2; exit 1; }
  TITLE=$(gh issue view "$ISSUE_NUMBER" --repo "$REPO" --json title -q .title) || { echo "Failed to fetch issue from $INPUT" >&2; exit 1; }
  BRANCH_NAME=$(title_to_branch "$TITLE")
  echo "Issue #$ISSUE_NUMBER: $TITLE"
elif echo "$INPUT" | grep -qE '^[0-9]{3,5}$'; then
  # Issue number (3-5 digits)
  ISSUE_NUMBER="$INPUT"
  REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner) || { echo "Failed to detect GitHub repo" >&2; exit 1; }
  TITLE=$(gh issue view "$ISSUE_NUMBER" --repo "$REPO" --json title -q .title) || { echo "Failed to fetch issue #$ISSUE_NUMBER" >&2; exit 1; }
  BRANCH_NAME=$(title_to_branch "$TITLE")
  echo "Issue #$ISSUE_NUMBER: $TITLE"
else
  # Plain branch name - sanitize to kebab-case
  BRANCH_NAME=$(title_to_branch "$INPUT")
fi

if [ -z "$BRANCH_NAME" ]; then
  echo "Could not determine branch name" >&2
  exit 1
fi

BASE_BRANCH=$(git base-branch) || exit 1

# Fetch the latest changes from the remote repository
git fetch --all

# Check for uncommitted changes and stash them if they exist
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Stashing uncommitted changes..."
  git stash
  STASHED=true
else
  STASHED=false
fi

# Checkout the base branch and pull
git checkout "$BASE_BRANCH"
git pull origin "$BASE_BRANCH"

# Create new branch or checkout existing one
if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
  echo "Branch '$BRANCH_NAME' already exists, checking out and updating from '$BASE_BRANCH'..."
  git checkout "$BRANCH_NAME"

  # Pop the stash if it was stashed
  if [ "$STASHED" = true ]; then
    echo "Applying stashed changes..."
    git stash pop
  fi

  git grlp
else
  git checkout -b "$BRANCH_NAME"

  # Pop the stash if it was stashed
  if [ "$STASHED" = true ]; then
    echo "Applying stashed changes..."
    git stash pop
  fi

  echo "Branch '$BRANCH_NAME' created from '$BASE_BRANCH' and checked out."
fi
