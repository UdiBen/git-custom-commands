#!/bin/sh

# Add all files, commit, and push to origin

message=$1

if [ -z "$message" ]; then
  echo "Commit message is not provided"
  exit 1
fi

echo "Files to be committed:"
git status --short | while IFS= read -r line; do
  status=$(echo "$line" | cut -c1-2 | tr -d ' ')
  case "$status" in
    D)  printf "\033[31m%s\033[0m\n" "$line" ;;
    M)  printf "\033[33m%s\033[0m\n" "$line" ;;
    A)  printf "\033[32m%s\033[0m\n" "$line" ;;
    ??) printf "\033[32m%s\033[0m\n" "$line" ;;
    *)  echo "$line" ;;
  esac
done
printf "\nProceed? [Y/n]: "
read answer

if [ "$answer" = "n" ] || [ "$answer" = "N" ]; then
  echo "Aborted."
  exit 1
fi

git add .
git commit -am "$message"
git push
